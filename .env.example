# ─── Vibrnd POS — environment variables ─────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Postgres (Supabase). Two URLs:
#   • DATABASE_URL → pooled connection used by the app at runtime
#     (Supabase → Project Settings → Database → Connection Pooling →
#      "Transaction" mode, port 6543)
#   • DIRECT_URL → direct connection used by `prisma db push` / migrations
#     (Supabase → Project Settings → Database → Connection String → "URI",
#      port 5432)
# Both URLs must include the password and end with `?pgbouncer=true` for the
# pooled URL on Vercel serverless.
DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# 32+ character random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="rotate-this-please-use-a-long-random-string"
