// Petpooja-style POS backend schema
// Single-outlet for v1; multi-outlet ready via Outlet relations.

generator client {
  provider      = "prisma-client-js"
  // Vercel's serverless runtime is Amazon Linux 2 with OpenSSL 3 — Prisma needs
  // the matching engine binary or it fails at startup with PrismaClientInitializationError.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled connection string used by the app at runtime (Supabase Transaction pooler, port 6543).
  url       = env("DATABASE_URL")
  // Direct connection used by `prisma db push` / `prisma migrate` (Supabase direct connection, port 5432).
  directUrl = env("DIRECT_URL")
}

model Outlet {
  id                  String  @id @default(cuid())
  name                String
  code                String  @unique
  address             String?
  phone               String?
  email               String?
  gstin               String?
  fssai               String?
  /// UPI VPA used to generate the dynamic QR at Settle (audit TASK 20).
  upiVpa              String?
  currency            String  @default("INR")
  timezone            String  @default("Asia/Kolkata")
  taxInclusive        Boolean @default(false) // when true, item prices already include GST
  loyaltyEarnPer      Float   @default(10) // 1 point earned per ₹N spent
  loyaltyRedeemRupees Float   @default(1) // 1 point = ₹N when redeemed
  tierSilverAt        Int     @default(500) // points threshold for Silver tier
  tierGoldAt          Int     @default(2000) // points threshold for Gold tier
  tierSilverMult      Float   @default(1.5) // earn multiplier at Silver
  tierGoldMult        Float   @default(2.0) // earn multiplier at Gold
  storeOpen           Boolean @default(true) // master switch — closed gates online orders
  kdsEnabled          Boolean @default(true) // when false the POS prints KOTs locally instead of pushing to /kds
  serviceChargePct    Float   @default(10) // default service charge % at Settle; set 0 to disable by default
  active              Boolean @default(true) // soft-delete

  // ─── Chain-inventory foundation (Prompt 1) ─────────────────────────
  /// What this outlet IS in the chain topology. OUTLET = customer-facing
  /// restaurant (has POS, menu, billing). BASE_STORE = chain warehouse that
  /// receives supplier POs and ships to outlets. BASE_KITCHEN = central
  /// commissary that produces semi-finished goods (e.g. cooked dal) from
  /// raw materials. BS / BK get a slimmed-down inventory-only UI; POS,
  /// menu, billing are hidden.
  kind                       String   @default("OUTLET") // OUTLET | BASE_STORE | BASE_KITCHEN
  /// 1-outlet → 1-BS mapping for v1. Null for non-OUTLET kinds.
  baseStoreOutletId          String?
  baseStoreOutlet            Outlet?  @relation("OutletBaseStore", fields: [baseStoreOutletId], references: [id])
  outletsServedByBs          Outlet[] @relation("OutletBaseStore")
  /// 1-outlet → 1-BK mapping for v1. Null for non-OUTLET kinds.
  baseKitchenOutletId        String?
  baseKitchenOutlet          Outlet?  @relation("OutletBaseKitchen", fields: [baseKitchenOutletId], references: [id])
  outletsServedByBk          Outlet[] @relation("OutletBaseKitchen")
  /// When true, Store Manager POs must be approved by a Cost Controller
  /// before they can be sent to the vendor. Owner can flip this off per
  /// outlet from Settings → Inventory.
  requireCostControlApproval Boolean  @default(true)
  /// When true, BK → Outlet transfers carry forward a configurable labour /
  /// overhead markup on top of the input cost. Default off.
  applyBKMarkupOnTransfer    Boolean  @default(false)
  bkMarkupPercent            Float    @default(0)
  /// Master switch for the multi-department inventory model (Store → Kitchen
  /// / Bar / Housekeeping). Default ON for new outlets; legacy outlets are
  /// flipped on by the backfill script. Disabling reverts the UI to the
  /// old flat per-outlet stock view.
  multiDeptInventoryEnabled  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items                 Item[]
  categories            Category[]
  orders                Order[]
  customers             Customer[]
  rawMaterials          RawMaterial[]
  expenses              Expense[]
  users                 User[]
  tables                DiningTable[]
  kots                  KitchenTicket[]
  discounts             Discount[]
  taxSlabs              TaxSlab[]
  activityLogs          ActivityLog[]
  stockMovements        StockMovement[]
  purchaseOrders        PurchaseOrder[]
  cashEntries           CashEntry[]
  notifications         Notification[]
  subOrderTypes         SubOrderType[]
  salesReturns          SalesReturn[]
  feedback              Feedback[]
  giftCards             GiftCard[]
  payments              Payment[]
  taskTemplates         TaskTemplate[]
  tasks                 Task[]
  dayCloses             DayClose[]
  overrides             OverrideRequest[]
  membershipPlans       MembershipPlan[]
  membershipRedemptions MembershipRedemption[]
  units                 Unit[]
  stockCounts           StockCount[]
  purchases             Purchase[]
  transfersSent         Transfer[]             @relation("TransfersSent")
  transfersReceived     Transfer[]             @relation("TransfersReceived")
  productionMasters     ProductionMaster[]
  productionRuns        ProductionRun[]
  vendorPayments        VendorPayment[]
  invSettings           InventorySetting[]
  reportNotifications   ReportNotification[]
  rolePermissions       RolePermission[]
  fixedAssets           FixedAsset[]
  assetAudits           AssetAudit[]
  printers              Printer[]

  departments    Department[]
  requisitions   Requisition[]
  grns           Grn[]
  vendorInvoices VendorInvoice[]
  coupons        Coupon[]
  discountUsages DiscountUsage[]
  itemTags       ItemTag[]
  tableGroups    TableGroup[]
  reservations   Reservation[]
  stockBatches   StockBatch[]

  // Customer Value Engine (Phase 1)
  walletAccounts     WalletAccount[]
  walletTransactions WalletTransaction[]
  campaigns          Campaign[]
  benefitDefs        BenefitDef[]
  redemptionHistory  RedemptionHistory[]
  otpChallenges      OtpChallenge[]
}

/// A stock-holding sub-unit within an outlet. Every outlet has at minimum a
/// STORE department; OUTLET-kind outlets typically also have KITCHEN / BAR /
/// HOUSEKEEPING. BASE_STORE / BASE_KITCHEN outlets have a single STORE dept
/// that holds the chain-level stock.
model Department {
  id        String   @id @default(cuid())
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  /// STORE | KITCHEN | BAR | HOUSEKEEPING | OTHER. STORE is the only dept
  /// with an external inbound channel — everything else gets stock via
  /// internal requisition from STORE.
  kind      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  stockMovements       StockMovement[]
  transfersOutbound    Transfer[]      @relation("TransferFromDept")
  transfersInbound     Transfer[]      @relation("TransferToDept")
  requisitionsRaised   Requisition[]   @relation("RequisitionFromDept")
  requisitionsReceived Requisition[]   @relation("RequisitionToDept")
  grns                 Grn[]
  stockBatches         StockBatch[]

  /// One STORE / KITCHEN / BAR / HOUSEKEEPING per outlet — extra OTHER
  /// instances allowed under unique names.
  @@unique([outletId, kind, name])
  @@index([outletId, active])
}

/// Audit trail — every critical action must drop a row here. The
/// columns mirror Box 8 of the POS-module spec: User / Role / Date /
/// Action / Reason / Old value / New value. `summary` stays as a
/// human-readable one-liner; `reason`, `oldValue`, `newValue` are the
/// structured fields the audit report queries.
model ActivityLog {
  id        String   @id @default(cuid())
  action    String // CREATE | UPDATE | DELETE | CANCEL | SETTLE | ACCEPT | REJECT
  entity    String // Order | Item | Discount | Customer | RawMaterial | KOT | Outlet | Expense
  entityId  String?
  summary   String
  actor     String   @default("system") // user email; "system" for unauthenticated
  /// Role at time of action — captures the privilege the user was
  /// exercising. Falls back to whatever the session user was at
  /// log-time; nullable for legacy rows seeded before this column.
  role      String?
  /// Captured reason for void / discount / comp / reprint / cancel
  /// actions. Nullable so harmless CREATEs don't need to invent text.
  reason    String?
  /// JSON snapshot of the prior state for UPDATE-style actions. Stored
  /// as a string to keep the schema neutral — readers JSON.parse on
  /// access. Capped at ~2KB by the application layer.
  oldValue  String?
  newValue  String?
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())

  @@index([outletId, createdAt])
  @@index([entity, entityId])
}

model User {
  id                 String            @id @default(cuid())
  name               String
  email              String            @unique
  passwordHash       String? // bcrypt-hashed; nullable for legacy seed
  /// Role registry now extends to inventory / procurement roles:
  /// OWNER | MANAGER | BILLER | CAPTAIN | STORE_MANAGER | COST_CONTROLLER
  /// | CHEF_HOD | BARTENDER_HOD | HOUSEKEEPING_HOD | ACCOUNTANT
  /// | PRODUCTION_MANAGER.
  role               String            @default("BILLER")
  active             Boolean           @default(true)
  commissionRate     Float             @default(0) // % of order revenue earned as commission
  outletId           String
  outlet             Outlet            @relation(fields: [outletId], references: [id])
  /// Department this user is scoped to. Nullable for outlet-wide roles
  /// (OWNER, MANAGER, BILLER, CAPTAIN, STORE_MANAGER who owns STORE,
  /// COST_CONTROLLER, ACCOUNTANT). Set for HODs (CHEF_HOD → KITCHEN,
  /// BARTENDER_HOD → BAR, HOUSEKEEPING_HOD → HOUSEKEEPING) and for
  /// PRODUCTION_MANAGER (set to a BK outlet's STORE dept).
  departmentId       String?
  department         Department?       @relation(fields: [departmentId], references: [id])
  assignedTasks      Task[]            @relation("AssignedTasks")
  createdTasks       Task[]            @relation("CreatedTasks")
  dayCloses          DayClose[]
  requestedOverrides OverrideRequest[] @relation("RequestedOverrides")
  approvedOverrides  OverrideRequest[] @relation("ApprovedOverrides")
  tableGroups        TableGroup[]      @relation("TableGroupCaptain")
  attributedOrders   Order[]           @relation("OrderCaptain")
  createdAt          DateTime          @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String
  rank      Int      @default(0)
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  items     Item[]
  createdAt DateTime @default(now())
}

model ItemChannelPrice {
  id        String  @id @default(cuid())
  itemId    String
  item      Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  /// One of: DINE_IN | PICKUP | DELIVERY | SWIGGY | ZOMATO | MAGICPIN | DOTPE
  channel   String
  price     Float
  available Boolean @default(true)

  @@unique([itemId, channel])
}

model Item {
  id                 String              @id @default(cuid())
  name               String
  shortCode          String?
  description        String?
  price              Float
  taxRate            Float               @default(5) // GST %
  imageUrl           String?
  active             Boolean             @default(true)
  outOfStock         Boolean             @default(false)
  isVeg              Boolean             @default(true)
  /// 4-way dietary marker per audit TASK 4 — overrides isVeg when set.
  /// VEG (green) | NON_VEG (red) | EGG (yellow) | JAIN (saffron)
  dietary            String              @default("VEG")
  station            String              @default("MAIN") // MAIN | TANDOOR | BAR | DESSERT
  categoryId         String
  category           Category            @relation(fields: [categoryId], references: [id])
  outletId           String
  outlet             Outlet              @relation(fields: [outletId], references: [id])
  recipes            Recipe[]
  orderItems         OrderItem[]
  kotLines           KitchenTicketLine[]
  variants           ItemVariant[]
  addons             Addon[]
  membershipBenefits MembershipBenefit[]
  channelPrices      ItemChannelPrice[]
  tagAssigns         ItemTagAssign[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

/// Menu-item tag (Spicy / Sweet / Chef Special / Contains Nuts / etc).
/// Tags are managed per outlet so each restaurant can brand their own
/// labels; the icon is a Lucide icon name (resolved client-side via a
/// curated registry — no arbitrary HTML). Color is a tailwind hue token
/// applied to the icon background on POS cards.
model ItemTag {
  id        String          @id @default(cuid())
  name      String
  icon      String          @default("Tag") // Lucide icon name; resolved client-side
  color     String          @default("slate") // tailwind hue: red | orange | amber | emerald | sky | violet | pink | slate
  rank      Int             @default(0)
  outletId  String
  outlet    Outlet          @relation(fields: [outletId], references: [id])
  assigns   ItemTagAssign[]
  createdAt DateTime        @default(now())

  @@unique([outletId, name])
}

/// Join table — many items × many tags. Composite PK avoids dupes when a
/// tag is toggled twice in the editor.
model ItemTagAssign {
  itemId String
  item   Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tagId  String
  tag    ItemTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
}

model ItemVariant {
  id      String   @id @default(cuid())
  itemId  String
  item    Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name    String // "Half" / "Full" / "Small" / "Medium" / "Large"
  price   Float // absolute price for this variant
  rank    Int      @default(0)
  recipes Recipe[]
}

model Addon {
  id                String             @id @default(cuid())
  itemId            String
  item              Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name              String // "Extra cheese" / "Less spicy" / "No onion"
  priceDelta        Float              @default(0)
  rank              Int                @default(0)
  recipeIngredients RecipeIngredient[]
}

model Customer {
  id                String               @id @default(cuid())
  name              String
  phone             String?
  email             String?
  address           String?
  gstin             String?
  tags              String? // CSV of segment tags
  allergies         String? // CSV — surfaced to the captain on every visit
  /// Free-form special notes captured at receptionist intake (Box 1 of
  /// the POS spec — "Special Notes"). Examples: "Wheelchair seating",
  /// "VIP family · sons name Aarav", "Wants extra pickle". Surfaced on
  /// every future visit alongside allergies.
  specialNotes      String?
  birthday          DateTime?
  anniversary       DateTime?
  loyaltyPoints     Int                  @default(0)
  outletId          String
  outlet            Outlet               @relation(fields: [outletId], references: [id])
  orders            Order[]
  loyaltyTxns       LoyaltyTransaction[]
  feedback          Feedback[]
  giftCards         GiftCard[]
  memberships       Membership[]
  reservations      Reservation[]
  /// Customer Value Engine — the wallet is the source of truth for
  /// campaign/cashback/refund credits. One account per customer, lazily
  /// created on first credit. Distinct from `loyaltyPoints` which stays
  /// on the Customer row for backwards compat.
  walletAccount     WalletAccount?
  redemptionHistory RedemptionHistory[]
  createdAt         DateTime             @default(now())

  @@index([phone])
}

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  delta      Int // positive = earn, negative = redeem
  balance    Int // running balance after this txn
  reason     String // EARN | REDEEM | ADJUST | EXPIRE
  orderId    String?
  note       String?
  outletId   String
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
}

model DiningTable {
  id           String        @id @default(cuid())
  name         String
  area         String        @default("Main")
  capacity     Int           @default(4)
  /// Canvas position for the floor-plan editor (audit TASK 5).
  /// Stored as percentage of the canvas (0..100) so it stays
  /// responsive across screen sizes.
  posX         Float         @default(50)
  posY         Float         @default(50)
  /// Visual shape — round / square / rectangle.
  shape        String        @default("ROUND")
  active       Boolean       @default(true)
  outletId     String
  outlet       Outlet        @relation(fields: [outletId], references: [id])
  /// Optional table-group assignment. When set + the group has a captain
  /// the receptionist's assign-table flow auto-attributes the order to
  /// that captain so they don't have to be picked manually.
  tableGroupId String?
  tableGroup   TableGroup?   @relation(fields: [tableGroupId], references: [id])
  orders       Order[]
  reservations Reservation[]
}

/// Section / zone of the floor plan that bundles a set of tables under a
/// default Captain. Lets the owner say "Aarav owns tables 1-8 every
/// evening". On receptionist handoff the order's captainId is filled
/// from the table's group automatically.
model TableGroup {
  id        String        @id @default(cuid())
  name      String
  captainId String?
  captain   User?         @relation(fields: [captainId], references: [id], name: "TableGroupCaptain")
  outletId  String
  outlet    Outlet        @relation(fields: [outletId], references: [id])
  tables    DiningTable[]
  createdAt DateTime      @default(now())

  @@index([outletId])
}

/// Future-time table booking. Receptionists create a Reservation when a
/// guest phones ahead; the floor plan renders the table as Reserved
/// until status flips to SEATED (auto-creates the linked Order) or
/// NO_SHOW / CANCELLED (frees the table).
model Reservation {
  id            String      @id @default(cuid())
  tableId       String
  table         DiningTable @relation(fields: [tableId], references: [id])
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  customerName  String
  customerPhone String?
  reservedFor   DateTime
  partySize     Int         @default(2)
  notes         String?
  /// PENDING (waiting for the guest) · SEATED (guest arrived, order
  /// created) · NO_SHOW (window passed) · CANCELLED (manually voided).
  status        String      @default("PENDING")
  /// Set when status = SEATED — points at the auto-created Order so the
  /// captain can resume billing immediately.
  orderId       String?
  outletId      String
  outlet        Outlet      @relation(fields: [outletId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([outletId, reservedFor])
  @@index([tableId, status])
}

model Order {
  id             String          @id @default(cuid())
  invoiceNo      String          @unique
  orderType      String // DINE_IN | PICKUP | DELIVERY | ONLINE
  status         String          @default("RUNNING") // RUNNING | SAVED | PRINTED | PAID | CANCELLED | PLACED | ACCEPTED | REJECTED | FOOD_READY | PICKED_UP | DELIVERED
  channel        String          @default("POS") // POS | SWIGGY | ZOMATO | MAGICPIN | DOTPE | WEB | PHONE
  subTotal       Float           @default(0)
  taxTotal       Float           @default(0)
  discount       Float           @default(0)
  discountCode   String?
  /// Mandatory reason captured when a Manager applies a manual
  /// discount (spec Box 2 "Discount Rights — Enter Reason (Required)").
  /// Nullable so coupon-driven / auto discounts don't have to provide
  /// one. Surfaced on the printed bill + audit trail alongside the
  /// discount value.
  discountReason String?
  grandTotal     Float           @default(0)
  amountPaid     Float           @default(0) // running total of payments received
  paymentMode    String? // CASH | CARD | UPI | ONLINE | DUE (last-used mode summary)
  tip            Float           @default(0)
  customerId     String?
  customer       Customer?       @relation(fields: [customerId], references: [id])
  /// Receipt-facing name + phone snapshot. Captured at place-order so the
  /// "Change customer name" action (POS access matrix) can edit the bill's
  /// printed name without retroactively renaming a saved Customer record
  /// across every historical bill. Nullable — legacy bills fall back to
  /// the linked Customer.name / Customer.phone in the UI.
  customerName   String?
  customerPhone  String?
  tableId        String?
  table          DiningTable?    @relation(fields: [tableId], references: [id])
  outletId       String
  outlet         Outlet          @relation(fields: [outletId], references: [id])
  items          OrderItem[]
  kots           KitchenTicket[]
  returns        SalesReturn[]
  feedback       Feedback[]
  giftCardTxns   GiftCardTxn[]
  payments       Payment[]
  notes          String?
  subOrderType   String? // e.g. "Parcel" / "Takeaway" / "Bar"
  captainId      String? // user id of the captain who took the order
  /// Captain relation — added so the live floor plan can join in the
  /// captain's name on the running-order tile without a separate
  /// User.findMany. FK already existed; this just teaches Prisma about
  /// the relationship so `include: { captain }` works.
  captain        User?           @relation(name: "OrderCaptain", fields: [captainId], references: [id])
  amendedAt      DateTime? // last time the bill was modified post-settlement
  reprintCount   Int             @default(0) // audit TASK 10 — leakage signal
  reprintReason  String? // last reason captured

  // Online / aggregator fields
  aggregatorOrderId String?
  deliveryAddress   String?
  deliveryOtp       String?
  riderName         String?
  riderPhone        String?
  locality          String? // derived/captured for delivery & locality reports
  reconciledAt      DateTime?
  reconciledAmount  Float? // what the aggregator actually paid out

  // Loyalty
  loyaltyEarned   Int @default(0)
  loyaltyRedeemed Int @default(0)

  createdAt DateTime  @default(now())
  closedAt  DateTime?

  // Customer Value Engine (Phase 1) — wallet ledger + campaign redemption trace
  walletTransactions WalletTransaction[]
  redemptionHistory  RedemptionHistory[]

  @@index([status, createdAt])
  @@index([outletId, createdAt])
  @@index([channel, status])
}

/// A physical/virtual KOT printer mapped to a kitchen station (department).
/// When a bill is sent, items are already split into one KitchenTicket per
/// station; each station's ticket is routed to the printer(s) assigned to that
/// station here.
model Printer {
  id        String   @id @default(cuid())
  name      String
  /// Station/department this printer serves — matches Item.station /
  /// KitchenTicket.station (MAIN | TANDOOR | BAR | DESSERT | …).
  station   String   @default("MAIN")
  /// Optional device target for the local print agent (IP:port, host, or
  /// device id). Null = the agent's default device for the station.
  target    String?
  active    Boolean  @default(true)
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())

  @@index([outletId, station, active])
}

model KitchenTicket {
  id            String              @id @default(cuid())
  kotNo         String              @unique
  orderId       String
  order         Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status        String              @default("NEW") // NEW | IN_PROGRESS | READY | SERVED | CANCELLED
  station       String              @default("MAIN") // MAIN | TANDOOR | BAR | DESSERT
  outletId      String
  outlet        Outlet              @relation(fields: [outletId], references: [id])
  lines         KitchenTicketLine[]
  notes         String?
  /// KOT idempotency — Print KOT button locks after first send; reprints
  /// require a reason and bump this counter (audit anti-leakage signal).
  printedCount  Int                 @default(0)
  reprintCount  Int                 @default(0)
  reprintReason String?
  createdAt     DateTime            @default(now())
  readyAt       DateTime?
  servedAt      DateTime?

  @@index([status, createdAt])
  @@index([outletId, status])
}

model KitchenTicketLine {
  id       String        @id @default(cuid())
  ticketId String
  ticket   KitchenTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  itemId   String
  item     Item          @relation(fields: [itemId], references: [id])
  name     String
  qty      Int
  note     String?
  status   String        @default("NEW") // NEW | READY
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId        String
  item          Item      @relation(fields: [itemId], references: [id])
  name          String // snapshot at order time
  price         Float // snapshot — includes variant + addons
  qty           Int
  taxRate       Float
  variantName   String? // e.g. "Half"
  addonsJson    String? // JSON snapshot: [{name, priceDelta}]
  note          String?
  /// Soft-void columns (Phase 2 POS actions). When voidedAt is set, the
  /// line is excluded from sub/tax/grand totals on the order but the row
  /// is preserved for audit. voidReason captures why the cashier/manager
  /// voided it (mandatory at the action layer — DB allows null only for
  /// rows seeded before this column landed).
  voidedAt      DateTime?
  voidReason    String?
  /// Line-level complimentary (Box 2 of the spec). When true the price
  /// is preserved on the row (so reports can still see "₹X was given
  /// away") but is excluded from order subtotal/tax/grand. compReason is
  /// optional per the spec but recommended.
  complimentary Boolean   @default(false)
  compReason    String?
  /// Cost of goods sold for this line — sum of FIFO-consumed batch rates
  /// times qty consumed at recipe-execute time. Snapshot at order place so
  /// changes to batches afterwards don't retroactively rewrite the bill's
  /// COGS. Zero for items without a recipe (drinks, packaged goods).
  cogs          Float     @default(0)
  createdAt     DateTime  @default(now())

  @@index([orderId, voidedAt])
}

model RawMaterial {
  id                  String    @id @default(cuid())
  name                String
  unit                String    @default("kg") // legacy single-unit, kept for backwards compat
  purchaseUnit        String? // unit used on supplier invoices
  consumptionUnit     String? // unit used by recipes
  conversionFactor    Float     @default(1) // 1 purchaseUnit = N consumptionUnit
  parLevel            Float     @default(0)
  minLevel            Float     @default(0)
  currentQty          Float     @default(0)
  avgCost             Float     @default(0)
  purchasePrice       Float     @default(0) // standard buy price
  transferPrice       Float     @default(0)
  reconciliationPrice Float     @default(0)
  taxType             String    @default("GST")
  taxPct              Float     @default(0)
  exciseDuty          Float     @default(0)
  brand               String?
  description         String?
  hsnCode             String?
  barcode             String?
  shortCode           String?
  imageUrl            String?
  isFavourite         Boolean   @default(false)
  active              Boolean   @default(true)
  categoryName        String?
  subCategory         String?
  supplierId          String?
  supplier            Supplier? @relation(fields: [supplierId], references: [id])
  outletId            String
  outlet              Outlet    @relation(fields: [outletId], references: [id])

  /// Where this raw material comes from:
  ///   PURCHASED — bought from suppliers (default for everything that existed
  ///               before the chain inventory work).
  ///   PRODUCED  — output of a production run at a Base Kitchen (e.g. cooked
  ///               dal). Carries an avg cost rolled forward from the inputs.
  ///   BOTH      — can be either, e.g. paneer that's sometimes bought and
  ///               sometimes produced in-house.
  source String @default("PURCHASED")

  /// CSV of department kinds (KITCHEN | BAR | HOUSEKEEPING | STORE) that
  /// are allowed to see + request this item. NULL or empty means the item
  /// is available to every department (typical for salt, oil, packaging
  /// material). The HOD requisition form + the department-scoped catalog
  /// views filter through this — a Chef HOD won't see "Vodka" if its
  /// allowedDepartments is "BAR".
  allowedDepartments String?

  recipes                   RecipeIngredient[]
  movements                 StockMovement[]
  poLines                   PurchaseOrderLine[]
  purchaseLines             PurchaseLine[]
  transferLines             TransferLine[]
  productionInputs          ProductionInputLine[]
  productionMastersAsOutput ProductionMaster[]    @relation("ProductionOutputRM")
  countLines                StockCountLine[]
  rmSuppliers               RawMaterialSupplier[]
  requisitionLines          RequisitionLine[]
  grnLines                  GrnLine[]
  vendorInvoiceLines        VendorInvoiceLine[]
  /// FIFO stock-batch ledger. Each GRN line spawns one StockBatch row with
  /// its own landed rate; consumption draws oldest-first. RawMaterial.currentQty
  /// is kept as a denormalised cache = sum of qtyRemaining across this RM's
  /// open batches at the relevant department.
  stockBatches              StockBatch[]
  createdAt                 DateTime              @default(now())
}

/// FIFO stock batch — the immutable lot of a raw material received in one
/// receipt event (GRN, opening backfill, stock count adjust, production
/// output, or chain transfer-in). Consumption picks the oldest open batch
/// first and decrements its qtyRemaining; this lets us compute COGS at
/// actual landed cost instead of running-average. RawMaterial.currentQty
/// remains as a fast denormalised cache.
model StockBatch {
  id            String      @id @default(cuid())
  rawMaterialId String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
  outletId      String
  outlet        Outlet      @relation(fields: [outletId], references: [id])
  /// Where this batch sits — typically the STORE dept for purchased
  /// material, the producing dept for production output, the receiving
  /// dept for an internal transfer.
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id])
  /// Total qty received in this batch. Never mutated after creation —
  /// consumption decrements qtyRemaining instead so we can audit
  /// "this batch was ₹120/kg and produced X COGS".
  qtyReceived   Float
  /// Live qty still on hand from this batch. 0 means fully consumed; we
  /// keep the row for audit + COGS history.
  qtyRemaining  Float
  /// Landed cost per consumption-unit (already includes apportioned
  /// freight/delivery/discount/tax from the GRN header where applicable).
  ratePerUnit   Float
  /// Discriminator — where this batch came from:
  ///   GRN_RECEIPT       — receipt against a PO or ad-hoc GRN (most common)
  ///   OPENING           — backfilled at migration from RawMaterial.currentQty
  ///   STOCK_COUNT       — closing-stock variance adjustment
  ///   PRODUCTION_OUTPUT — output of a production run
  ///   TRANSFER_IN       — receiver of an internal/chain transfer
  ///   ADJUSTMENT        — manual correction
  source        String      @default("GRN_RECEIPT")
  /// FK back to the originating GRN line, when source = GRN_RECEIPT.
  grnLineId     String?     @unique
  grnLine       GrnLine?    @relation(fields: [grnLineId], references: [id])
  /// FK back to the originating GRN header (denormalised so we can list
  /// "batches from GRN X" without joining through the line).
  grnId         String?
  grn           Grn?        @relation(fields: [grnId], references: [id])
  /// Vendor batch number from the supplier (printed on the cartons).
  /// Distinct from this StockBatch.id (our internal ID) and from grnLineId.
  batchNo       String?
  expiryDate    DateTime?
  receivedAt    DateTime    @default(now())
  /// When fully consumed — null until qtyRemaining hits zero. Lets COGS
  /// reports answer "which batches contributed to last week's COGS".
  closedAt      DateTime?

  @@index([rawMaterialId, departmentId, qtyRemaining])
  @@index([outletId, receivedAt])
  @@index([grnId])
}

/// Many-to-many between RawMaterial and Supplier with the per-pair negotiated rate.
model RawMaterialSupplier {
  id             String      @id @default(cuid())
  rawMaterialId  String
  rawMaterial    RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  supplierId     String
  supplier       Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  negotiatedRate Float       @default(0)
  isPrimary      Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@unique([rawMaterialId, supplierId])
}

model StockMovement {
  id            String      @id @default(cuid())
  rawMaterialId String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  delta         Float // signed: positive = in, negative = out
  /// Reason codes — extended for chain inventory:
  ///   SALE | CANCEL_REVERSE | ADJUST | PURCHASE | WASTAGE | OPENING
  ///   PRODUCTION_INPUT  (consumed by a ProductionRun at BK)
  ///   PRODUCTION_OUTPUT (created by a ProductionRun at BK)
  ///   INTERNAL_TRANSFER (Store → Kitchen / Bar / HK within same outlet)
  ///   CHAIN_TRANSFER    (BS → Outlet or BK → Outlet)
  ///   GRN_RECEIPT       (vendor goods received against PO/standalone GRN)
  reason        String
  refType       String? // Order | Outlet | Manual | Grn | Requisition | ProductionRun
  refId         String?
  qtyBefore     Float
  qtyAfter      Float
  note          String?
  outletId      String
  outlet        Outlet      @relation(fields: [outletId], references: [id])
  /// Department this movement happened in. Nullable while we backfill;
  /// once Prompt 1's backfill runs every row points at the outlet's STORE
  /// (or the right sub-dept for movements that came in via Requisition).
  /// Going forward all new movements MUST set this — services validate it.
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([outletId, createdAt])
  @@index([rawMaterialId, createdAt])
  @@index([departmentId, createdAt])
}

model Supplier {
  id              String                @id @default(cuid())
  name            String
  company         String?
  contact         String?
  email           String?
  phone           String?
  pan             String?
  gstin           String?
  fssai           String?
  type            String                @default("SUPPLIER") // SUPPLIER | THIRD_PARTY | BOTH
  registerAddress String?
  shippingAddress String?
  state           String?
  city            String?
  pinCode         String?
  address         String? // legacy free-form
  termsOfPayment  String?
  termsOfDelivery String?
  /// Days of credit this supplier extends — 0 means cash-on-delivery.
  /// Shown alongside the rate card so the SM remembers what they negotiated.
  creditDays      Int                   @default(0)
  openingBalance  Float                 @default(0)
  active          Boolean               @default(true)
  rawMaterials    RawMaterial[]
  purchaseOrders  PurchaseOrder[]
  purchases       Purchase[]
  vendorPayments  VendorPayment[]
  rmSuppliers     RawMaterialSupplier[]
  vendorInvoices  VendorInvoice[]
  createdAt       DateTime              @default(now())
}

model PurchaseOrder {
  id                String              @id @default(cuid())
  poNo              String              @unique
  supplierId        String
  supplier          Supplier            @relation(fields: [supplierId], references: [id])
  /// Extended PO state machine (Prompt 1):
  ///   DRAFT
  ///   → PENDING_CC_APPROVAL  (when outlet.requireCostControlApproval = true;
  ///                          otherwise auto-promotes to APPROVED on submit)
  ///   → APPROVED  →  REJECTED (with ccRejectionReason)
  ///   → SENT (PO emailed / downloaded by SM)
  ///   → PARTIALLY_RECEIVED  (one or more GRNs against this PO, more to come)
  ///   → CLOSED              (all qty received OR manually closed)
  ///   → CANCELLED
  status            String              @default("DRAFT")
  subTotal          Float               @default(0)
  taxTotal          Float               @default(0)
  grandTotal        Float               @default(0)
  notes             String?
  /// Cost-controller approval audit columns. Null until the CC acts.
  ccApprovedById    String?
  ccApprovedAt      DateTime?
  ccRejectionReason String?
  /// Department that raised this PO (typically the outlet's STORE). Nullable
  /// while we backfill; required for newly-created POs once Prompt 1 lands.
  departmentId      String?
  /// Optional link back to the requisition that triggered this PO — set
  /// when a store manager raises a PO to cover a shortfall on an APPROVED
  /// req. 1:N (one req can spawn multiple POs across suppliers).
  requisitionId     String?
  requisition       Requisition?        @relation(fields: [requisitionId], references: [id])
  outletId          String
  outlet            Outlet              @relation(fields: [outletId], references: [id])
  lines             PurchaseOrderLine[]
  purchases         Purchase[]
  grns              Grn[]
  /// Stock Purchases (vendor bills) recorded against this PO.
  stockPurchases    VendorInvoice[]
  receivedAt        DateTime?
  /// When an SM uses the multi-supplier auto-PO flow, N POs are created in
  /// a single submit (one per preferred supplier). batchKey ties them
  /// together so the list view can show "3 draft POs created from this
  /// auto-PO" and the SM can review them as a group. Null for hand-crafted
  /// POs.
  batchKey          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([outletId, status])
  @@index([requisitionId])
  @@index([batchKey])
}

model PurchaseOrderLine {
  id               String        @id @default(cuid())
  poId             String
  po               PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  rawMaterialId    String
  rawMaterial      RawMaterial   @relation(fields: [rawMaterialId], references: [id])
  qty              Float
  unit             String
  unitPrice        Float
  lineTotal        Float
  /// True when this item wasn't on the supplier's rate card at PO time —
  /// the SM explicitly added it via "Add other item" and acknowledged the
  /// warning. Surfaces on dashboards as off-card spend.
  offCard          Boolean       @default(false)
  /// When the SM edited the rate at PO time, this holds the rate-card rate
  /// at the moment of override. Null means the rate matches the card (or
  /// the item was off-card and had no card rate to begin with).
  rateChangedFrom  Float?
  /// Reason the SM gave when overriding the card rate or adding off-card.
  /// Required by the client dialog when either of the above is set.
  rateChangeReason String?
  /// Running tally of how much of this line has been received via GRNs.
  /// Used to drive the PO status transition PARTIALLY_RECEIVED → CLOSED.
  qtyReceived      Float         @default(0)
  grnLines         GrnLine[]
}

/// One recipe per (item, variant) pair. Items WITHOUT variants don't have
/// recipes in this model — the recipes UI filters to items that have at
/// least one ItemVariant. Per-variant separation lets Burger (Veg) and
/// Burger (Chicken) consume completely different raw materials.
model Recipe {
  id            String             @id @default(cuid())
  itemId        String
  item          Item               @relation(fields: [itemId], references: [id])
  itemVariantId String
  itemVariant   ItemVariant        @relation(fields: [itemVariantId], references: [id], onDelete: Cascade)
  ingredients   RecipeIngredient[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([itemId, itemVariantId])
  @@index([itemVariantId])
}

/// Ingredient line on a recipe.
///   • addonId NULL  → part of the BASE recipe (always consumed when the
///                     item+variant is sold).
///   • addonId SET   → consumed ONLY when the customer selects that
///                     addon. Each addon can have its own ingredient set
///                     per-variant (e.g. Extra Cheese on Burger-Veg may
///                     pull 30g cheese, on Burger-Chicken may pull 40g).
model RecipeIngredient {
  id            String      @id @default(cuid())
  recipeId      String
  recipe        Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawMaterialId String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
  addonId       String?
  addon         Addon?      @relation(fields: [addonId], references: [id], onDelete: Cascade)
  qty           Float
  unit          String

  @@index([recipeId, addonId])
}

model TaxSlab {
  id        String   @id @default(cuid())
  name      String // "GST 5%" / "GST 12%" / "GST 18%" / "VAT 5%"
  rate      Float // 5 / 12 / 18
  active    Boolean  @default(true)
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())

  @@unique([outletId, name])
}

/// Discount master — extended per the Vibrnd discount module spec.
/// One row drives 4 discount types (Percentage / Fixed / BOGO / Fixed Price)
/// across 8 channels (POS / Zomato / Swiggy / Online Platform / Kiosk /
/// GPay / OS Aggregator / Mr Divert / IRCTC). Conditional fields are
/// stored sparsely — only the columns that the picked type / scope needs
/// are filled.
///
/// Legacy columns (`code`, `name`, `type`, `isAuto`, `hourFrom/To`) are
/// kept so historical orders / reports continue to work without a
/// backfill. New entries should use the modern column names instead.
model Discount {
  id          String    @id @default(cuid())
  /// Public coupon code. Required by the schema but can be auto-generated
  /// (e.g. "AUTO-{cuid}") for discounts that don't need a typed code —
  /// validationMode controls whether the cashier is prompted for it.
  code        String    @unique
  /// Internal title shown in the discount list. The spec calls this "Title";
  /// `name` is kept for backward compat with existing queries.
  name        String
  /// Discount type — FIXED | PERCENTAGE | BOGO | FIXED_PRICE.
  /// Legacy values FLAT / PERCENT auto-map to FIXED / PERCENTAGE via the
  /// save action so existing rows keep working.
  type        String
  /// % for PERCENTAGE, ₹ for FIXED / FIXED_PRICE. Ignored for BOGO (uses
  /// DiscountBogo.bogoValue instead).
  value       Float
  /// Min cart core total for the discount to fire. Legacy "minOrder".
  minOrder    Float     @default(0)
  /// Max cart core total — null means no upper bound. Spec §1 field 11.
  maxOrder    Float?
  /// % discount rupee cap. Used only for PERCENTAGE.
  maxDiscount Float?
  active      Boolean   @default(true)
  validFrom   DateTime?
  validTo     DateTime?
  /// Legacy isAuto flag — superseded by validationMode (NONE = automatic).
  /// Kept so the existing pickAutoDiscount engine keeps reading it until
  /// the engine is migrated in Phase 2.
  isAuto      Boolean   @default(false)
  daysOfWeek  String?

  /// 24h time-of-day window stored as "HH:MM" strings (Petpooja-style).
  /// Legacy hourFrom/hourTo (integer hour) are kept for the existing
  /// engine; new code should read timeFrom/timeTo.
  timeFrom String?
  timeTo   String?
  hourFrom Int?
  hourTo   Int?

  /// Channel — STICKY after first save. One of: POS · ONLINE_PLATFORM ·
  /// ZOMATO · SWIGGY · KIOSK · GPAY · OS_AGGREGATOR · MR_DIVERT · IRCTC.
  channel        String  @default("POS")
  /// CSV of order types (DELIVERY · PICKUP · DINE_IN). At least one.
  orderTypes     String  @default("DELIVERY,PICKUP,DINE_IN")
  /// AMOUNT — applies to bill. PAYMENT_TYPE — applies only when the
  /// matching payment method is selected at settle.
  applyOn        String  @default("AMOUNT")
  /// CSV of payment method ids (cash / card / upi / etc) — only used when
  /// applyOn = PAYMENT_TYPE.
  paymentMethods String?

  /// Apply at the pre-tax subtotal (CORE) or the post-tax grand total
  /// (TOTAL). Spec §1 field 8.
  applyAt String @default("CORE")

  /// Scope — ALL · CATEGORIES · ITEMS. The applicableIds CSV holds the
  /// matching category ids OR item ids depending on this enum.
  applicableScope String  @default("ALL")
  applicableIds   String?

  /// Validation mode — NONE (auto) · CODE_ONLY (typed code, no master) ·
  /// COUPON_VALIDATED (typed code against Coupon master).
  validationMode String @default("NONE")

  description String?
  /// T&C — surfaced on POS and printed bill per spec.
  terms       String?

  outletId  String
  outlet    Outlet          @relation(fields: [outletId], references: [id])
  bogo      DiscountBogo?
  coupons   Coupon[]
  usages    DiscountUsage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt

  @@index([outletId, active])
  @@index([outletId, isAuto, active])
  @@index([outletId, channel, active])
}

/// 1:1 with Discount when type = BOGO. Sparse table keeps the main row
/// clean for the 90% of discounts that aren't BOGO.
model DiscountBogo {
  discountId       String   @id
  discount         Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  /// Minimum cart core total — separate from Discount.minOrder so BOGO
  /// rules can have a higher floor than generic discounts.
  itemAmountMin    Float?
  /// Buy-side filter.
  buyScope         String   @default("ALL") // ALL | CATEGORIES | ITEMS
  buyScopeIds      String? // CSV
  /// Get-side filter (what becomes free / discounted).
  getScope         String   @default("ALL")
  getScopeIds      String?
  buyQty           Int      @default(1)
  getQty           Int      @default(1)
  /// PERCENTAGE — bogoValue is %. FIXED — bogoValue is ₹ off the Get items.
  bogoValueType    String   @default("PERCENTAGE")
  bogoValue        Float    @default(100)
  /// Pricing strategy on the Get items: LOWER (cheapest = best for guest) ·
  /// HIGHER (priciest = clearance win) · SAME (Get must match Buy SKU).
  getItemPricing   String   @default("LOWER")
  /// Same for the Buy side when there are extras: LOWER | HIGHER.
  buyItemPricing   String   @default("LOWER")
  /// When true the POS prints the free-qty line. When false the discount
  /// silently spreads across the qualifying items.
  showFreeQtyOnPos Boolean  @default(true)
  /// Optional cap — only this rupee value of the Buy side counts.
  buyAmountCap     Float?
}

/// Coupon master — only used when Discount.validationMode = COUPON_VALIDATED.
/// One Discount can have many Coupon codes (e.g. WELCOME10, WELCOME20).
model Coupon {
  id             String             @id @default(cuid())
  discountId     String
  discount       Discount           @relation(fields: [discountId], references: [id], onDelete: Cascade)
  code           String
  outletId       String
  outlet         Outlet             @relation(fields: [outletId], references: [id])
  maxRedemptions Int? // null = unlimited
  perUserLimit   Int? // null = unlimited
  usedCount      Int                @default(0)
  expiresAt      DateTime?
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now())
  redemptions    CouponRedemption[]

  @@unique([outletId, code])
  @@index([code])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId    String
  customerId String?
  redeemedAt DateTime @default(now())

  @@index([couponId, redeemedAt])
  @@index([orderId])
}

/// Per-bill snapshot of a fired discount — immutable audit row. Powers
/// the "₹ redeemed this month" stat on the list page + any redemption
/// report.
model DiscountUsage {
  id            String   @id @default(cuid())
  discountId    String
  discount      Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  orderId       String
  customerId    String?
  appliedAmount Float
  channel       String?
  outletId      String
  outlet        Outlet   @relation(fields: [outletId], references: [id])
  createdAt     DateTime @default(now())

  @@index([discountId, createdAt])
  @@index([outletId, createdAt])
  @@index([orderId])
}

model SubOrderType {
  id         String   @id @default(cuid())
  name       String
  parentType String // DINE_IN | PICKUP | DELIVERY
  rank       Int      @default(0)
  active     Boolean  @default(true)
  outletId   String
  outlet     Outlet   @relation(fields: [outletId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([outletId, name])
}

model MembershipPlan {
  id                String              @id @default(cuid())
  name              String
  price             Float
  durationDays      Int // 365 for "one year"
  active            Boolean             @default(true)
  outletId          String // owner outlet — but memberships work across all outlets
  outlet            Outlet              @relation(fields: [outletId], references: [id])
  benefits          MembershipBenefit[]
  memberships       Membership[]
  createdAt         DateTime            @default(now())
  WalletTransaction WalletTransaction[]
}

model MembershipBenefit {
  id           String                 @id @default(cuid())
  planId       String
  plan         MembershipPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  name         String // "One free tea per day"
  itemId       String? // grants free instance of this menu item
  item         Item?                  @relation(fields: [itemId], references: [id])
  qtyPerDay    Int                    @default(1)
  /// Optional link into the Customer Value Engine benefit registry.
  /// New benefits created via the CVE membership builder point here so
  /// evaluation flows through the shared rule/benefit code. Historic
  /// benefits keep working via the fields above; the CVE resolver
  /// falls back to (itemId, qtyPerDay) when benefitDefId is null.
  benefitDefId String?
  benefitDef   BenefitDef?            @relation(fields: [benefitDefId], references: [id])
  redemptions  MembershipRedemption[]
}

model Membership {
  id          String                 @id @default(cuid())
  customerId  String
  customer    Customer               @relation(fields: [customerId], references: [id])
  planId      String
  plan        MembershipPlan         @relation(fields: [planId], references: [id])
  startsAt    DateTime
  expiresAt   DateTime
  active      Boolean                @default(true)
  redemptions MembershipRedemption[]
  otps        MembershipOtp[]
  createdAt   DateTime               @default(now())

  @@index([customerId, active])
  @@index([expiresAt])
}

model MembershipRedemption {
  id           String            @id @default(cuid())
  membershipId String
  membership   Membership        @relation(fields: [membershipId], references: [id])
  benefitId    String
  benefit      MembershipBenefit @relation(fields: [benefitId], references: [id])
  businessDay  DateTime // midnight of the day — used for the unique cap
  outletId     String // where redeemed
  outlet       Outlet            @relation(fields: [outletId], references: [id])
  orderId      String? // tied to the bill it was applied on
  createdAt    DateTime          @default(now())

  // Foolproof daily cap: one row per (member, benefit, day) ACROSS all outlets
  @@unique([membershipId, benefitId, businessDay])
  @@index([businessDay])
}

model MembershipOtp {
  id           String     @id @default(cuid())
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])
  code         String // 6-digit
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime   @default(now())

  @@index([membershipId, createdAt])
}

model TaskTemplate {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String // RECURRING | ADHOC | TODO
  cadence     String    @default("ONE_OFF") // ONE_OFF | DAILY | WEEKLY | MONTHLY
  defaultRole String? // OWNER | MANAGER | BILLER | CAPTAIN
  slaMinutes  Int? // soft SLA before task goes overdue
  active      Boolean   @default(true)
  outletId    String
  outlet      Outlet    @relation(fields: [outletId], references: [id])
  tasks       Task[]
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([outletId, active])
}

model Task {
  id           String        @id @default(cuid())
  title        String
  description  String?
  type         String // RECURRING | ADHOC | TODO
  status       String        @default("OPEN") // OPEN | IN_PROGRESS | DONE | CANCELLED | OVERDUE
  templateId   String?
  template     TaskTemplate? @relation(fields: [templateId], references: [id])
  assignedRole String? // role this task belongs to (any user with that role can claim)
  assignedToId String? // optional specific user
  assignedTo   User?         @relation("AssignedTasks", fields: [assignedToId], references: [id])
  dueAt        DateTime?
  completedAt  DateTime?
  photoUrl     String?
  createdById  String?
  createdBy    User?         @relation("CreatedTasks", fields: [createdById], references: [id])
  outletId     String
