  location    String? // e.g. "Hall A", "Kitchen", "Storeroom"
  qty         Int              @default(1)
  unitValue   Float            @default(0) // ₹ per unit at acquisition (optional)
  condition   String           @default("GOOD") // GOOD | FAIR | DAMAGED | DISCARDED
  purchasedAt DateTime?
  notes       String?
  active      Boolean          @default(true)
  outletId    String
  outlet      Outlet           @relation(fields: [outletId], references: [id])
  auditLines  AssetAuditLine[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([outletId, category])
  @@index([outletId, active])
}

model AssetAudit {
  id            String           @id @default(cuid())
  outletId      String
  outlet        Outlet           @relation(fields: [outletId], references: [id])
  auditedById   String?
  auditedAt     DateTime         @default(now())
  /// Total lines with variance > 0 — surfaced as anti-theft signal.
