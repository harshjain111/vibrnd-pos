  id               String         @id @default(cuid())
  challanNo        String?
  transferDate     DateTime
  status           String         @default("SENT") // SENT | RECEIVED | CANCELLED
  /// Outlet-level legacy fields — kept for back-compat reporting. New
  /// transfers populate these from the source/dest departments' outlets.
  senderOutletId   String
  sender           Outlet         @relation("TransfersSent", fields: [senderOutletId], references: [id])
  receiverOutletId String
  receiver         Outlet         @relation("TransfersReceived", fields: [receiverOutletId], references: [id])
  /// Department-level transfer endpoints. Nullable while we backfill;
  /// services validate after Prompt 1 lands.
  fromDepartmentId String?
  fromDepartment   Department?    @relation("TransferFromDept", fields: [fromDepartmentId], references: [id])
  toDepartmentId   String?
  toDepartment     Department?    @relation("TransferToDept", fields: [toDepartmentId], references: [id])
  /// Kind of transfer for reporting + permissions:
  ///   INTERNAL — within the same outlet (Store → Kitchen/Bar/HK)
  ///   CHAIN    — between outlets (BS → Outlet, BK → Outlet, etc.)
  kind             String         @default("CHAIN")
  /// When this Transfer was spawned by a Requisition approval, link back
  /// so the requisition's "delivered" status can roll up automatically.
  requisitionId    String?        @unique
  requisition      Requisition?   @relation(fields: [requisitionId], references: [id])
  notes            String?
  lines            TransferLine[]
  sentById         String?
  receivedById     String?
  receivedAt       DateTime?
  createdAt        DateTime       @default(now())

  @@index([receiverOutletId, status])
  @@index([senderOutletId, status])
  @@index([fromDepartmentId, status])
  @@index([toDepartmentId, status])
}

